{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild/node",
    "tsBuildInfoFile": "./.tsbuild/node.tsbuildinfo",
    "types": ["node", "vitest"]
  },
  "include": ["vite.config.ts"]
}
