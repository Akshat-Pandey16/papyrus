{
  "name": "papyrus",
  "version": "0.1.0",
  "private": true,
  "description": "Free, open-source, self-hostable PDF processing web app.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "web": "pnpm --filter @papyrus/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "upgrade": "pnpm -r update --latest && pnpm dedupe && pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14"
  }
}
