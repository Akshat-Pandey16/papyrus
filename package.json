{
  "name": "papyrus",
  "version": "0.1.0",
  "private": true,
  "description": "Free, open-source, self-hostable PDF processing web app.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "scripts": {
    "web": "pnpm --filter @papyrus/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "upgrade": "pnpm -r update --latest && pnpm dedupe && pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15"
  }
}
