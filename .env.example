# =====================================================================
# Papyrus — environment configuration
# Copy to .env and fill in values for local dev.
# Production deploys must set these via secret manager, not files.
# =====================================================================

# ---- Runtime ---------------------------------------------------------
PAPYRUS_ENV=development                          # development | staging | production
LOG_LEVEL=INFO                                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=pretty                                # pretty (dev) | json (prod)

# ---- API service -----------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLIC_URL=http://localhost:8000             # external base URL clients see
API_CORS_ORIGINS=http://localhost:5173           # comma-separated

# ---- Database --------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://papyrus:papyrus@localhost:5432/papyrus
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ---- Redis -----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Object storage (S3-compatible) ----------------------------------
S3_ENDPOINT_URL=http://localhost:9000            # MinIO local; unset for AWS
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=papyrus
S3_SECRET_ACCESS_KEY=papyrus-secret
S3_BUCKET_UPLOADS=papyrus-uploads
S3_BUCKET_OUTPUTS=papyrus-outputs
S3_PRESIGN_EXPIRES_SECONDS=900
S3_FORCE_PATH_STYLE=true                         # required for MinIO

# ---- Auth ------------------------------------------------------------
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TTL_SECONDS=900                       # 15 min
JWT_REFRESH_TTL_SECONDS=2592000                  # 30 days
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# ---- Quotas / limits -------------------------------------------------
ANON_MAX_FILE_BYTES=26214400                     # 25 MiB
USER_MAX_FILE_BYTES=524288000                    # 500 MiB
ANON_DAILY_JOB_QUOTA=10
USER_DAILY_JOB_QUOTA=200
JOB_RESULT_TTL_SECONDS=86400                     # 24h

# ---- Email -----------------------------------------------------------
EMAIL_PROVIDER=smtp                              # smtp | ses | postmark
EMAIL_FROM=noreply@papyrus.local
SMTP_HOST=localhost
SMTP_PORT=1025                                   # MailHog
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false

# ---- Telemetry -------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=papyrus-api

# ---- Privacy ---------------------------------------------------------
ZERO_RETENTION_MODE=false                        # if true, purge artifacts immediately after job

# ---- Network ---------------------------------------------------------
# Comma-separated CIDR/IPs that are allowed to set X-Forwarded-For.
# Leave empty to ignore XFF entirely (recommended unless you sit behind
# an LB/ingress you control). Example: TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1
TRUSTED_PROXIES=

# ---- Web (Vite reads VITE_* only) ------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=Papyrus
VITE_SENTRY_DSN=
VITE_MAX_FILE_BYTES=524288000
